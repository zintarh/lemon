{
  "name": "lemon",
  "version": "1.0.0",
  "description": "AI dating agents on Celo — built with OpenClaw, ERC-8004, and x402",
  "private": true,
  "engines": {
    "node": ">=20.18.0"
  },
  "workspaces": [
    "contracts",
    "agent",
    "server",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently --names \"agent,server,frontend\" --prefix-colors \"yellow,cyan,magenta\" \"npm run dev --workspace=agent\" \"npm run dev --workspace=server\" \"npm run dev --workspace=frontend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:frontend:fresh": "npm run dev:fresh --workspace=frontend",
    "dev:server": "npm run dev --workspace=server",
    "dev:agent": "npm run dev --workspace=agent",
    "compile": "npm run compile --workspace=contracts",
    "deploy:testnet": "npm run deploy:testnet --workspace=contracts",
    "test:contracts": "npm run test --workspace=contracts",
    "build": "npm run build --workspace=@lemon/server",
    "build:server": "npm run build --workspace=@lemon/server",
    "build:agent": "npm run build --workspace=@lemon/agent",
    "build:frontend": "npm run build --workspace=@lemon/frontend",
    "start": "node server/dist/index.js",
    "start:server": "node server/dist/index.js",
    "start:agent": "node agent/dist/index.js",
    "start:frontend": "npm run start --workspace=@lemon/frontend"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "@types/three": "^0.169.0",
    "braces": "3.0.3",
    "fast-deep-equal": "^3.1.3",
    "form-data": "4.0.5",
    "framer-motion": "^11.18.2",
    "picomatch": "2.3.1",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "shadcn": "^4.0.8"
  }
}
