# ─── Celo Network ────────────────────────────────────────────
CELO_RPC_URL=https://forno.celo.org
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
DEPLOYER_PRIVATE_KEY=0x...

# ─── Contract Addresses (populated after deploy) ─────────────
LEMON_AGENT_CONTRACT=0x3A61fc4Bc8cCbD77EcBFC8986E39Bcd57730C0e1
LEMON_DATE_CONTRACT=0x2A25cfcB3765749f0ce232568FF4D4002A8d445D
LEMON_NFT_CONTRACT=0xe40e2a9A980A34Aa34F066450cA68CBdfC26C05a

# ─── SelfClaw (agent identity + verification) ────────────────
# No API key needed — agents authenticate via Ed25519 keypairs
# Keys are generated automatically at agent registration time
# SELFCLAW_API_KEY is returned per-agent after verification completes

# ─── ERC-8004 / ChaosChain ───────────────────────────────────
CHAOSCHAIN_API_KEY=...
ERC8004_IDENTITY_REGISTRY=0x...
ERC8004_REPUTATION_REGISTRY=0x...

# ─── Thirdweb (x402 payments) ─────────────────────────────────
THIRDWEB_SECRET_KEY=...
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=...
SERVER_WALLET_ADDRESS=0x...

# ─── OpenAI (image generation + conversation) ─────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# ─── X (Twitter) API ─────────────────────────────────────────
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_SECRET=...
TWITTER_BEARER_TOKEN=...

# ─── IPFS (Pinata) ────────────────────────────────────────────
PINATA_API_KEY=...
PINATA_SECRET_KEY=...
PINATA_GATEWAY=https://gateway.pinata.cloud
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:4000
NEXT_PUBLIC_NETWORK=testnet
SERVER_PORT=4000
AGENT_PORT=5000

# ─── Frontend (public) ────────────────────────────────────────
NEXT_PUBLIC_LEMON_AGENT_CONTRACT=0x3A61fc4Bc8cCbD77EcBFC8986E39Bcd57730C0e1
NEXT_PUBLIC_LEMON_DATE_CONTRACT=0x2A25cfcB3765749f0ce232568FF4D4002A8d445D
NEXT_PUBLIC_LEMON_NFT_CONTRACT=0xe40e2a9A980A34Aa34F066450cA68CBdfC26C05a
NEXT_PUBLIC_PRIVY_APP_ID=...
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=...

# ─── Frontend API routes (Vercel / Next server only) ─────────
# Same Supabase project as backend; service role — never NEXT_PUBLIC_*
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── AI (agent conversations + image generation) ─────────────
# ANTHROPIC_API_KEY no longer needed — using OpenAI GPT-4o instead

# ─── Server network flag ──────────────────────────────────────
NETWORK=testnet  # or mainnet
