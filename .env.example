# ─── Celo Network ────────────────────────────────────────────
CELO_RPC_URL=https://forno.celo.org
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
DEPLOYER_PRIVATE_KEY=0x...

# ─── Contract Addresses (populated after deploy) ─────────────
LEMON_AGENT_CONTRACT=0x3A61fc4Bc8cCbD77EcBFC8986E39Bcd57730C0e1
LEMON_DATE_CONTRACT=0x2A25cfcB3765749f0ce232568FF4D4002A8d445D
LEMON_NFT_CONTRACT=0xe40e2a9A980A34Aa34F066450cA68CBdfC26C05a

# ─── SelfClaw (agent identity + verification) ────────────────
# No API key needed — agents authenticate via Ed25519 keypairs
# Keys are generated automatically at agent registration time
# SELFCLAW_API_KEY is returned per-agent after verification completes

# ─── ERC-8004 / ChaosChain ───────────────────────────────────
CHAOSCHAIN_API_KEY=...
ERC8004_IDENTITY_REGISTRY=0x...
ERC8004_REPUTATION_REGISTRY=0x...
# Optional endpoints included in agentURI metadata (used by AgentScan/8004 explorers)
# If omitted, defaults derive from NEXT_PUBLIC_APP_URL / SERVER_URL.
ERC8004_A2A_BASE_URL=https://lemonagents.xyz
# Optional per-agent URL template. `{wallet}` is replaced with agent wallet address.
ERC8004_A2A_URL_TEMPLATE=https://lemonagents.xyz/.well-known/agents/{wallet}.json
ERC8004_MCP_URL=https://lemonagents.xyz/mcp

# ─── x402 payments (thirdweb facilitator) ─────────────────────
THIRDWEB_SECRET_KEY=...
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=...
# Lemon treasury wallet — receives all date payments in cUSD
LEMON_TREASURY_ADDRESS=0x...
# Date cost in cents (default 100 = $1.00)
DATE_COST_CENTS=100

# ─── OpenAI (image generation + conversation) ─────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# ─── X (Twitter) API ─────────────────────────────────────────
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_SECRET=...
TWITTER_BEARER_TOKEN=...

# ─── IPFS (Pinata) ────────────────────────────────────────────
PINATA_API_KEY=...
PINATA_SECRET_KEY=...
PINATA_GATEWAY=https://gateway.pinata.cloud
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:4000
NEXT_PUBLIC_NETWORK=testnet
SERVER_PORT=4000
AGENT_PORT=5000


LEMON_INTERNAL_SECRET=

TELEGRAM_WEBHOOK_SECRET=

NEXT_PUBLIC_LEMON_AGENT_CONTRACT_OLD=0x365acB045184F93bA6D3a64ccb62De5a1F2988cD
NEXT_PUBLIC_LEMON_DATE_CONTRACT_OLD=0x44f1fD960A5415a339fEc73C099eED2A679b4322
NEXT_PUBLIC_LEMON_NFT_CONTRACT_OLD=0xab468FE43dCa3442f0b3b693fBBd40301df93303

NEXT_PUBLIC_LEMON_AGENT_CONTRACT=0x294B2A8e1CBFCF04E6A281fc86f0af29886E1e33
NEXT_PUBLIC_LEMON_DATE_CONTRACT=0x20589F889f86379b71D13A1E89C38be56ef6f03E
NEXT_PUBLIC_LEMON_NFT_CONTRACT=0x2E3d2292ca35bF18874900F01Af587d305fcA9F6



NEXT_PUBLIC_PRIVY_APP_ID=...
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=...

# ─── Frontend API routes (Vercel / Next server only) ─────────
# Same Supabase project as backend; service role — never NEXT_PUBLIC_*
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── AI (agent conversations + image generation) ─────────────
# ANTHROPIC_API_KEY no longer needed — using OpenAI GPT-4o instead

# ─── Server network flag ──────────────────────────────────────
NETWORK=testnet  # or mainnet
